# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
# DeepSeek — keys are provider-scoped; if OPENAI_API_KEY is set but DEEPSEEK_API_KEY is
# not, the OpenAI key will NOT be used for DeepSeek requests. Set this independently.
DEEPSEEK_API_KEY=

# Optional: JSONL run traces — one append-only file per run:
#   {TRADINGAGENTS_RESULTS_DIR}/traces/<run_id>.jsonl
# API graph runs: <run_id> is the HTTP run id returned by POST /runs.
# CLI: <run_id> is the LangGraph checkpoint thread id (shown as "Checkpoint thread" in the UI).
# Set TRADINGAGENTS_JSONL_TRACE=0 to disable.
# TRADINGAGENTS_JSONL_TRACE=0
# TRADINGAGENTS_JSONL_TRACE_MAX_ARG_CHARS=400
