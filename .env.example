# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=
# DeepSeek — keys are provider-scoped; if OPENAI_API_KEY is set but DEEPSEEK_API_KEY is
# not, the OpenAI key will NOT be used for DeepSeek requests. Set this independently.
DEEPSEEK_API_KEY=
